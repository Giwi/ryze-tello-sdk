{
  "plugins": [
    "plugins/markdown",
    "plugins/summarize"
  ],
  "source": {
    "includePattern": ".+\\.js(doc|x)?$",
    "excludePattern": "bower_components|(^|\\/|\\\\)_"
  },
  "sourceType": "module",
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": [
      "jsdoc",
      "closure"
    ]
  },
  "opts": {
    "encoding": "utf8",
    "destination": "./docs",
    "recurse": true,
    "readme": "./README.md",
    "tutorials": "./tutorials",
    "template": "./src/doc-template"
  }
}