{
  "name": "@giwisoft/ryze-tello-sdk",
  "author": {
    "name": "Giwi"
  },
  "version": "0.0.3",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p . && esbuild src/www/js/vendor.js --bundle --minify --alias:moment=dayjs --outfile=dist/www/assets/vendor.js && cp src/www/*.html dist/www/",
    "dev": "tsx src/index.ts",
    "start": "npm run build && node dist/index.js",
    "mock": "tsx src/servers/mock_server.ts",
    "doc": "npm run build && jsdoc dist -c .jsdoc.json",
    "test": "tsx --test test/*.ts"
  },
  "files": [
    "./dist/"
  ],
  "dependencies": {
    "bootstrap": "^4.6.2",
    "chart.js": "^2.9.4",
    "dayjs": "^1.11.21",
    "jquery": "^3.7.1",
    "open": "^8.0.3",
    "popper.js": "^1.16.1",
    "websocket": "^1.0.33"
  },
  "optionalDependencies": {
    "mqtt": "^4.2.6"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/websocket": "^1.0.10",
    "esbuild": "^0.28.1",
    "jsdoc": "^4.0.5",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
